---
import BaseLayout from "@layouts/BaseLayout.astro";
import Icon from "@components/Icon.astro";
import { PERGUNTAS, BENEFICIOS, FALLBACK } from "@data/simulador";
import { ICON_PATHS } from "@lib/icons";

// Ícones necessários no cliente (resultado + benefícios).
const nomesIcones = new Set<string>(["shield-check", "arrow-right", "arrow-left"]);
[...BENEFICIOS, FALLBACK].forEach((b) => nomesIcones.add(b.icon));
const icones: Record<string, string> = {};
nomesIcones.forEach((n) => (icones[n] = ICON_PATHS[n] ?? ""));

const config = { perguntas: PERGUNTAS, beneficios: BENEFICIOS, fallback: FALLBACK, icones };
---

<BaseLayout
  title="Simulador de benefícios"
  description="Responda 4 perguntas simples e descubra a quais benefícios sociais você pode ter direito. Gratuito, no seu aparelho, sem pedir nome, CPF ou senha."
  canonical="/ferramentas/simulador"
>
  <div class="max-w-[680px] mx-auto px-4 pt-7">
    <div class="text-center mb-2">
      <span class="inline-flex items-center gap-1.5 px-3 py-[5px] rounded-pill bg-orange-100 text-orange-700 text-sm font-bold">
        <Icon name="calculator" size={16} /> Ferramenta gratuita
      </span>
      <h1 class="mt-3 mb-1">Simulador de benefícios</h1>
      <p class="text-ink-600 m-0">Responda 4 perguntas simples. Leva menos de 1 minuto.</p>
    </div>

    <div class="bg-white border border-ink-200 rounded-lg shadow-sm p-6 mt-5 min-h-[420px]">
      <div id="sim-app" aria-live="polite"></div>
      <noscript>
        <p class="text-ink-700">
          O simulador precisa de JavaScript. Sem ele, veja diretamente o
          <a href="/bolsa-familia">guia do Bolsa Família</a> para entender as regras.
        </p>
      </noscript>
    </div>

    <p class="text-center text-sm text-ink-600 mt-4 pb-2">
      🔒 Não pedimos seu nome, CPF ou senha. Nada é salvo.
    </p>
  </div>

  <script type="application/json" id="sim-config" set:html={JSON.stringify(config)} is:inline />

  <script>
    type Pergunta = { key: string; title: string; help: string; options: { value: string; label: string }[] };
    type Beneficio = { id: string; title: string; why: string; icon: string; artigoUrl: string; condicoes: Record<string, string[]> };
    type Config = { perguntas: Pergunta[]; beneficios: Beneficio[]; fallback: Beneficio; icones: Record<string, string> };

    const el = document.getElementById("sim-config");
    const app = document.getElementById("sim-app");
    if (el && app) {
      const cfg: Config = JSON.parse(el.textContent || "{}");
      const { perguntas, beneficios, fallback, icones } = cfg;

      let step = 0;
      let done = false;
      const answers: Record<string, string> = {};

      const svg = (name: string, size = 24, color = "currentColor") =>
        `<svg width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${icones[name] || ""}</svg>`;

      function calcular(): Beneficio[] {
        const out = beneficios.filter((b) =>
          Object.entries(b.condicoes).every(([k, vals]) => vals.includes(answers[k]))
        );
        return out.length ? out : [fallback];
      }

      function renderStep() {
        const p = perguntas[step];
        const total = perguntas.length;
        const picked = answers[p.key];
        const segmentos = Array.from({ length: total }, (_, i) =>
          `<span class="flex-1 h-2 rounded-pill ${i < step + 1 ? "bg-primary" : "bg-ink-200"}"></span>`
        ).join("");
        const opcoes = p.options
          .map(
            (o) => `
          <button type="button" role="radio" aria-checked="${picked === o.value}" data-value="${o.value}"
            class="sim-choice flex items-center gap-3 w-full min-h-control-lg text-left p-4 rounded-md border-thick transition-colors duration-fast font-body ${
              picked === o.value
                ? "bg-green-50 border-primary shadow-focus-ring"
                : "bg-white border-ink-250 shadow-xs hover:border-green-300"
            }">
            <span class="flex-1 min-w-0"><span class="block text-lg font-semibold text-ink-900">${o.label}</span></span>
            <span aria-hidden="true" class="flex-none w-[26px] h-[26px] rounded-pill border-thick flex items-center justify-center ${
              picked === o.value ? "border-primary bg-primary" : "border-ink-400"
            }">${picked === o.value ? '<svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12.5l4.5 4.5L19 7" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>' : ""}</span>
          </button>`
          )
          .join("");

        app!.innerHTML = `
          <div class="w-full">
            <div class="flex items-baseline justify-between mb-2">
              <span class="font-body text-sm font-bold text-green-700 tracking-wide uppercase">Passo ${step + 1} de ${total}</span>
            </div>
            <div class="flex gap-1.5" aria-hidden="true">${segmentos}</div>
          </div>
          <h2 class="mt-5 mb-1 text-xl">${p.title}</h2>
          <p class="mt-0 mb-4 text-ink-600">${p.help}</p>
          <div class="flex flex-col gap-2.5" role="radiogroup" aria-label="${p.title}">${opcoes}</div>
          <div class="flex gap-2.5 mt-6">
            ${
              step > 0
                ? `<button type="button" id="sim-back" class="inline-flex items-center justify-center gap-2 min-h-control-md h-control-md px-5 font-body text-base font-bold rounded-md border-thick border-transparent bg-transparent text-ink-900 hover:bg-ink-100">${svg("arrow-left", 18)} Voltar</button>`
                : ""
            }
            <div class="flex-1"></div>
            <button type="button" id="sim-next" ${picked ? "" : "disabled"}
              class="inline-flex items-center justify-center gap-2 min-h-control-lg h-control-lg px-7 font-body text-lg font-bold rounded-md border-thick border-transparent ${
                picked ? "bg-cta text-white hover:bg-cta-hover shadow-xs cursor-pointer" : "bg-ink-200 text-ink-500 cursor-not-allowed"
              }">${step < total - 1 ? "Continuar" : "Ver resultado"} ${svg("arrow-right", 18)}</button>
          </div>`;

        app!.querySelectorAll<HTMLButtonElement>(".sim-choice").forEach((btn) => {
          btn.addEventListener("click", () => {
            answers[p.key] = btn.dataset.value!;
            renderStep();
          });
        });
        document.getElementById("sim-back")?.addEventListener("click", () => {
          if (step > 0) step--;
          renderStep();
        });
        document.getElementById("sim-next")?.addEventListener("click", () => {
          if (!answers[p.key]) return;
          if (step < total - 1) {
            step++;
            renderStep();
          } else {
            done = true;
            renderResult();
          }
        });
      }

      function renderResult() {
        const results = calcular();
        const n = results.length;
        const linhas = results
          .map(
            (r) => `
          <div class="flex gap-3 items-start p-4 border border-green-200 bg-green-50 rounded-md">
            <span class="w-11 h-11 flex-none rounded-md bg-white text-green-700 flex items-center justify-center">${svg(r.icon, 24, "#0A5446")}</span>
            <div>
              <div class="font-bold text-ink-900 text-[17px]">${r.title}</div>
              <div class="text-[15px] text-ink-600">${r.why}</div>
              <a href="${r.artigoUrl}" class="inline-flex items-center gap-1 text-green-700 font-semibold text-sm mt-1">Saiba mais ${svg("arrow-right", 14)}</a>
            </div>
          </div>`
          )
          .join("");

        app!.innerHTML = `
          <div class="text-center mb-2">
            <span class="w-16 h-16 rounded-pill bg-green-100 text-green-700 inline-flex items-center justify-center mb-2">${svg("shield-check", 34)}</span>
            <h2 class="my-1">Você pode ter direito a ${n} benefício${n !== 1 ? "s" : ""}</h2>
            <p class="text-ink-600 m-0">Este é um resultado estimado. Confirme sempre nos canais oficiais.</p>
          </div>
          <div class="flex flex-col gap-2.5 my-5">${linhas}</div>
          <div role="note" class="flex gap-3 px-5 py-4 rounded-md border-l-4 bg-info-50 border-l-info-600 font-body">
            <span class="flex-none flex mt-0.5 text-info-600">${svg("info", 22)}</span>
            <div><div class="text-base font-bold mb-0.5 text-info-700">Importante</div>
            <div class="text-base text-ink-800 leading-normal">O simulador é apenas uma orientação. A decisão final depende da análise oficial do CadÚnico.</div></div>
          </div>
          <div class="flex gap-2.5 mt-5 flex-wrap">
            <a href="/bolsa-familia" class="inline-flex items-center justify-center gap-2 min-h-control-md h-control-md px-5 font-body text-base font-bold rounded-md border-thick border-transparent bg-primary text-white hover:bg-primary-strong shadow-xs no-underline">Ler o guia do Bolsa Família ${svg("arrow-right", 18)}</a>
            <button type="button" id="sim-restart" class="inline-flex items-center justify-center gap-2 min-h-control-md h-control-md px-5 font-body text-base font-bold rounded-md border-thick border-transparent bg-transparent text-ink-900 hover:bg-ink-100">Refazer simulação</button>
          </div>`;

        document.getElementById("sim-restart")?.addEventListener("click", () => {
          step = 0;
          done = false;
          for (const k of Object.keys(answers)) delete answers[k];
          renderStep();
        });
      }

      renderStep();
    }
  </script>
</BaseLayout>
