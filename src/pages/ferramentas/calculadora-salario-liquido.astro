---
import BaseLayout from "@layouts/BaseLayout.astro";
import Icon from "@components/Icon.astro";
import Alert from "@components/feedback/Alert.astro";
import { SALARIO } from "@data/salario";
import { SITE } from "@config/site";
import { urlAbsoluta, formatarData } from "@lib/utils";
import { softwareAppSchema } from "@lib/seo";

const { inss, irrf, fontes, atualizadoEm } = SALARIO;

const schema = [
  softwareAppSchema({
    name: "Calculadora de Salário Líquido (CLT) 2026",
    description:
      "Digite o salário bruto e o número de dependentes e veja o líquido, com os descontos de INSS e Imposto de Renda de 2026. Gratuito, no seu aparelho.",
    url: urlAbsoluta(Astro.site ?? SITE.url, "/ferramentas/calculadora-salario-liquido"),
  }),
];
---

<BaseLayout
  title="Calculadora de Salário Líquido 2026"
  description="Digite o salário bruto e veja o líquido em 2026, com os descontos de INSS e Imposto de Renda (isenção até R$ 5.000). Gratuito e no seu aparelho."
  canonical="/ferramentas/calculadora-salario-liquido"
  schema={schema}
>
  <div class="max-w-[680px] mx-auto px-4 pt-7">
    <div class="text-center mb-2">
      <span class="inline-flex items-center gap-1.5 px-3 py-[5px] rounded-pill bg-orange-100 text-orange-700 text-sm font-bold">
        <Icon name="calculator" size={16} /> Ferramenta gratuita
      </span>
      <h1 class="mt-3 mb-1">Calculadora de Salário Líquido 2026</h1>
      <p class="text-ink-600 m-0">Veja quanto sobra do salário depois do INSS e do Imposto de Renda.</p>
    </div>

    <div class="bg-white border border-ink-200 rounded-lg shadow-sm p-6 mt-5">
      <div class="flex flex-col gap-4">
        <div class="flex flex-col gap-2">
          <label for="bruto" class="font-body text-sm font-semibold text-ink-900">Salário bruto (por mês)</label>
          <div class="flex items-center min-h-control-md px-4 bg-white border-thick border-ink-250 rounded-md focus-within:border-green-500 focus-within:shadow-focus-ring transition-[border-color,box-shadow] duration-fast">
            <span class="text-ink-600 font-semibold mr-1">R$</span>
            <input id="bruto" type="text" inputmode="decimal" placeholder="Ex.: 3.000,00" class="flex-1 min-w-0 border-0 outline-none bg-transparent font-body text-base text-ink-900 py-3" />
          </div>
        </div>
        <div class="flex flex-col gap-2">
          <label for="dependentes" class="font-body text-sm font-semibold text-ink-900">Número de dependentes</label>
          <div class="flex items-center min-h-control-md px-4 bg-white border-thick border-ink-250 rounded-md focus-within:border-green-500 focus-within:shadow-focus-ring transition-[border-color,box-shadow] duration-fast max-w-[160px]">
            <input id="dependentes" type="number" min="0" step="1" value="0" class="flex-1 min-w-0 border-0 outline-none bg-transparent font-body text-base text-ink-900 py-3" />
          </div>
          <span class="font-body text-sm text-ink-600">Cada dependente abate R$ {irrf.deducaoDependente.toLocaleString("pt-BR", { minimumFractionDigits: 2 })} da base do IR.</span>
        </div>
      </div>

      <button type="button" id="calc" class="mt-5 w-full inline-flex items-center justify-center gap-2 min-h-control-lg h-control-lg px-7 font-body text-lg font-bold rounded-md border-thick border-transparent bg-cta text-white hover:bg-cta-hover shadow-xs cursor-pointer">
        Calcular <Icon name="arrow-right" size={18} />
      </button>

      <!-- Resultado -->
      <div id="resultado" class="hidden mt-5">
        <div class="p-5 rounded-lg bg-green-600 text-white text-center">
          <div class="text-sm opacity-85 font-semibold">Salário líquido estimado</div>
          <div id="liquido" class="font-heading font-extrabold text-3xl my-1">R$ 0,00</div>
        </div>
        <div class="mt-3 border border-ink-200 rounded-lg overflow-hidden">
          <div class="flex justify-between px-4 py-3 border-b border-ink-200">
            <span class="text-ink-700">Salário bruto</span><span id="r-bruto" class="font-bold text-ink-900 tabular-nums">—</span>
          </div>
          <div class="flex justify-between px-4 py-3 border-b border-ink-200">
            <span class="text-ink-700">− INSS</span><span id="r-inss" class="font-bold text-error-700 tabular-nums">—</span>
          </div>
          <div class="flex justify-between px-4 py-3 border-b border-ink-200">
            <span class="text-ink-700">− Imposto de Renda</span><span id="r-irrf" class="font-bold text-error-700 tabular-nums">—</span>
          </div>
          <div class="flex justify-between px-4 py-3 bg-green-50">
            <span class="text-green-800 font-bold">= Líquido</span><span id="r-liquido" class="font-bold text-green-800 tabular-nums">—</span>
          </div>
        </div>
      </div>
      <p id="erro" class="hidden text-error-700 text-sm mt-3" role="alert"></p>
    </div>

    <div class="mt-4">
      <Alert tone="info" title="Novidade de 2026: isenção até R$ 5.000">
        Quem recebe até <strong>R$ 5.000</strong> por mês fica <strong>isento</strong> do Imposto de Renda na fonte. Entre R$ 5.000 e R$ 7.350 há uma redução que diminui até zerar.
      </Alert>
    </div>

    <p class="text-sm text-ink-600 mt-4 pb-2">
      🔒 Nada é salvo. Estimativa para CLT — não considera pensão alimentícia, plano de saúde nem outras deduções. Tabelas de {formatarData(new Date(atualizadoEm))}.
      Fontes: {fontes.map((f, i) => (<>{i > 0 ? " · " : ""}<a href={f.href} target="_blank" rel="noopener noreferrer" class="font-semibold">{f.label}</a></>))}
    </p>
  </div>

  <script type="application/json" id="tabelas" set:html={JSON.stringify({ inss, irrf })} is:inline></script>
  <script>
    type Faixa = { ate: number | null; aliquota: number; deduzir: number };
    const el = document.getElementById("tabelas");
    const { inss, irrf } = el ? JSON.parse(el.textContent || "{}") : { inss: null, irrf: null };
    const brutoEl = document.getElementById("bruto") as HTMLInputElement | null;
    const depEl = document.getElementById("dependentes") as HTMLInputElement | null;
    const box = document.getElementById("resultado");
    const erroEl = document.getElementById("erro");
    const reais = (n: number) => n.toLocaleString("pt-BR", { style: "currency", currency: "BRL" });
    const parse = (v: string) => parseFloat((v || "").replace(/[^\d.,]/g, "").replace(/\./g, "").replace(",", "."));

    function calcINSS(s: number): number {
      const base = Math.min(s, inss.teto);
      const f = inss.faixas.find((x: Faixa) => x.ate === null || base <= x.ate) ?? inss.faixas[inss.faixas.length - 1];
      return Math.max(0, base * f.aliquota - f.deduzir);
    }
    function tabelaIRRF(base: number): number {
      const f = irrf.faixas.find((x: Faixa) => x.ate === null || base <= x.ate);
      return Math.max(0, base * f.aliquota - f.deduzir);
    }
    function calcIRRF(bruto: number, inssV: number, deps: number): number {
      if (bruto <= irrf.redutor.isencaoAte) return 0;
      const base = bruto - inssV - deps * irrf.deducaoDependente;
      const t = tabelaIRRF(base);
      const red = bruto <= irrf.redutor.zeraAcima ? irrf.redutor.coefA - irrf.redutor.coefB * bruto : 0;
      return Math.max(0, t - red);
    }

    function set(id: string, v: string) {
      const n = document.getElementById(id);
      if (n) n.textContent = v;
    }

    function calcular() {
      erroEl?.classList.add("hidden");
      const bruto = parse(brutoEl?.value || "");
      const deps = Math.max(0, parseInt(depEl?.value || "0") || 0);
      if (!isFinite(bruto) || bruto <= 0) {
        box?.classList.add("hidden");
        if (erroEl) {
          erroEl.textContent = "Digite um salário bruto válido (ex.: 3.000,00).";
          erroEl.classList.remove("hidden");
        }
        return;
      }
      const inssV = calcINSS(bruto);
      const irrfV = calcIRRF(bruto, inssV, deps);
      const liq = bruto - inssV - irrfV;
      set("liquido", reais(liq));
      set("r-bruto", reais(bruto));
      set("r-inss", "− " + reais(inssV));
      set("r-irrf", "− " + reais(irrfV));
      set("r-liquido", reais(liq));
      box?.classList.remove("hidden");
    }

    document.getElementById("calc")?.addEventListener("click", calcular);
    [brutoEl, depEl].forEach((n) =>
      n?.addEventListener("keydown", (e) => {
        if ((e as KeyboardEvent).key === "Enter") calcular();
      })
    );
  </script>
</BaseLayout>
