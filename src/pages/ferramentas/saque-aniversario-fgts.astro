---
import BaseLayout from "@layouts/BaseLayout.astro";
import Icon from "@components/Icon.astro";
import Alert from "@components/feedback/Alert.astro";
import { SAQUE_ANIVERSARIO } from "@data/fgts";
import { SITE } from "@config/site";
import { urlAbsoluta, formatarData } from "@lib/utils";
import { softwareAppSchema } from "@lib/seo";

const { faixas, fontes, atualizadoEm } = SAQUE_ANIVERSARIO;

const schema = [
  softwareAppSchema({
    name: "Simulador do Saque-Aniversário do FGTS",
    description:
      "Digite o saldo do seu FGTS e veja quanto poderia sacar no saque-aniversário. Gratuito, no seu aparelho, sem coletar dados.",
    url: urlAbsoluta(Astro.site ?? SITE.url, "/ferramentas/saque-aniversario-fgts"),
  }),
];

const pct = (n: number) => `${(n * 100).toFixed(0)}%`;
const reais = (n: number) => n.toLocaleString("pt-BR", { style: "currency", currency: "BRL" });
const faixaLabel = (f: (typeof faixas)[number], i: number) => {
  const min = i === 0 ? 0 : (faixas[i - 1].ate ?? 0);
  if (f.ate === null) return `Acima de ${reais(min)}`;
  if (i === 0) return `Até ${reais(f.ate)}`;
  return `${reais(min + 0.01)} a ${reais(f.ate)}`;
};
---

<BaseLayout
  title="Simulador do Saque-Aniversário do FGTS"
  description="Digite o saldo do seu FGTS e veja quanto poderia sacar no saque-aniversário, com a tabela oficial de alíquotas e parcela adicional. Gratuito."
  canonical="/ferramentas/saque-aniversario-fgts"
  schema={schema}
>
  <div class="max-w-[680px] mx-auto px-4 pt-7">
    <div class="text-center mb-2">
      <span class="inline-flex items-center gap-1.5 px-3 py-[5px] rounded-pill bg-orange-100 text-orange-700 text-sm font-bold">
        <Icon name="wallet" size={16} /> Ferramenta gratuita
      </span>
      <h1 class="mt-3 mb-1">Simulador do Saque-Aniversário do FGTS</h1>
      <p class="text-ink-600 m-0">Digite o saldo do seu FGTS e veja quanto poderia sacar.</p>
    </div>

    <div class="bg-white border border-ink-200 rounded-lg shadow-sm p-6 mt-5">
      <div class="flex flex-col gap-2 w-full">
        <label for="saldo" class="font-body text-sm font-semibold text-ink-900">Saldo total do seu FGTS</label>
        <div class="flex items-center min-h-control-md px-4 bg-white border-thick border-ink-250 rounded-md focus-within:border-green-500 focus-within:shadow-focus-ring transition-[border-color,box-shadow] duration-fast">
          <span class="text-ink-600 font-semibold mr-1">R$</span>
          <input
            id="saldo"
            name="saldo"
            type="text"
            inputmode="decimal"
            placeholder="Ex.: 5.000,00"
            class="flex-1 min-w-0 border-0 outline-none bg-transparent font-body text-base text-ink-900 py-3"
          />
        </div>
        <span class="font-body text-sm text-ink-600">Some o saldo de todas as suas contas do FGTS. Veja no app FGTS.</span>
      </div>

      <button
        type="button"
        id="fgts-calcular"
        class="mt-4 w-full inline-flex items-center justify-center gap-2 min-h-control-lg h-control-lg px-7 font-body text-lg font-bold rounded-md border-thick border-transparent bg-cta text-white hover:bg-cta-hover shadow-xs cursor-pointer"
      >
        Calcular <Icon name="arrow-right" size={18} />
      </button>

      <!-- Resultado -->
      <div id="fgts-resultado" class="hidden mt-5 p-5 rounded-lg bg-green-600 text-white text-center">
        <div class="text-sm opacity-85 font-semibold">Você poderia sacar aproximadamente</div>
        <div id="fgts-valor" class="font-heading font-extrabold text-3xl my-1">R$ 0,00</div>
        <div id="fgts-detalhe" class="text-sm opacity-90"></div>
      </div>
      <p id="fgts-erro" class="hidden text-error-700 text-sm mt-3" role="alert"></p>

      <!-- Tabela de referência -->
      <div class="mt-6">
        <div class="text-[13px] font-bold tracking-[0.06em] uppercase text-green-600 mb-2">Tabela oficial</div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="text-left">
                <th class="py-2 px-3 bg-green-50 text-green-800 font-bold rounded-l-sm">Faixa de saldo</th>
                <th class="py-2 px-3 bg-green-50 text-green-800 font-bold">Alíquota</th>
                <th class="py-2 px-3 bg-green-50 text-green-800 font-bold rounded-r-sm">Parcela adicional</th>
              </tr>
            </thead>
            <tbody>
              {
                faixas.map((f, i) => (
                  <tr class="fgts-row border-b border-ink-200" data-i={i}>
                    <td class="py-2.5 px-3 text-ink-800">{faixaLabel(f, i)}</td>
                    <td class="py-2.5 px-3 font-bold text-ink-900 tabular-nums">{pct(f.aliquota)}</td>
                    <td class="py-2.5 px-3 text-ink-800 tabular-nums">{f.adicional > 0 ? `+ ${reais(f.adicional)}` : "—"}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="mt-4">
      <Alert tone="warning" title="Atenção antes de optar pelo saque-aniversário">
        Ao aderir ao saque-aniversário, você <strong>não pode</strong> sacar o saldo total do FGTS se for demitido sem justa causa —
        recebe apenas a multa de 40%. Pense bem antes de mudar da modalidade "saque-rescisão".
      </Alert>
    </div>

    <p class="text-sm text-ink-600 mt-4 pb-2">
      🔒 Nada é salvo. Cálculo estimado com base na tabela da Lei nº 8.036/90. Atualizado em {formatarData(new Date(atualizadoEm))}.
      Fontes: {fontes.map((f, i) => (<>{i > 0 ? " · " : ""}<a href={f.href} target="_blank" rel="noopener noreferrer" class="font-semibold">{f.label}</a></>))}
    </p>
  </div>

  <script type="application/json" id="fgts-faixas" set:html={JSON.stringify(faixas)} is:inline></script>
  <script>
    type Faixa = { ate: number | null; aliquota: number; adicional: number };
    const el = document.getElementById("fgts-faixas");
    const faixas: Faixa[] = el ? JSON.parse(el.textContent || "[]") : [];
    const input = document.getElementById("saldo") as HTMLInputElement | null;
    const btn = document.getElementById("fgts-calcular");
    const box = document.getElementById("fgts-resultado");
    const valorEl = document.getElementById("fgts-valor");
    const detalheEl = document.getElementById("fgts-detalhe");
    const erroEl = document.getElementById("fgts-erro");
    const reais = (n: number) => n.toLocaleString("pt-BR", { style: "currency", currency: "BRL" });

    function parseSaldo(v: string): number {
      // pt-BR: ponto = milhar, vírgula = decimal.
      const limpo = v.replace(/[^\d.,]/g, "").replace(/\./g, "").replace(",", ".");
      return parseFloat(limpo);
    }

    function calcular() {
      const saldo = parseSaldo(input?.value || "");
      erroEl?.classList.add("hidden");
      document.querySelectorAll<HTMLElement>(".fgts-row").forEach((r) => r.classList.remove("bg-green-50"));
      if (!isFinite(saldo) || saldo <= 0) {
        box?.classList.add("hidden");
        if (erroEl) {
          erroEl.textContent = "Digite um saldo válido (ex.: 5.000,00).";
          erroEl.classList.remove("hidden");
        }
        return;
      }
      const idx = faixas.findIndex((f) => f.ate === null || saldo <= f.ate);
      const f = faixas[idx];
      const total = saldo * f.aliquota + f.adicional;
      if (valorEl) valorEl.textContent = reais(total);
      if (detalheEl)
        detalheEl.textContent = `${(f.aliquota * 100).toFixed(0)}% de ${reais(saldo)}${f.adicional > 0 ? ` + ${reais(f.adicional)}` : ""}`;
      box?.classList.remove("hidden");
      document.querySelector<HTMLElement>(`.fgts-row[data-i="${idx}"]`)?.classList.add("bg-green-50");
    }

    btn?.addEventListener("click", calcular);
    input?.addEventListener("keydown", (e) => {
      if ((e as KeyboardEvent).key === "Enter") calcular();
    });
  </script>
</BaseLayout>
