---
/**
 * FAQAccordion — lista de perguntas/respostas em acordeão. Usa <details>/<summary>
 * nativos: acessível por teclado e sem JavaScript (melhor para performance e
 * para o público em 3G). Renderizado a partir de faq[] do frontmatter; o mesmo
 * array alimenta o schema FAQPage (JSON-LD), garantindo schema = conteúdo visível.
 */
interface ItemFAQ {
  pergunta: string;
  resposta: string;
}
interface Props {
  items: ItemFAQ[];
}
const { items } = Astro.props;
---

{
  items.length > 0 && (
    <div class="flex flex-col border border-ink-200 rounded-lg overflow-hidden bg-white">
      {items.map((it, i) => (
        <details class="faq-item group" open={i === 0}>
          <summary class="flex items-center justify-between gap-3 w-full min-h-control-lg px-5 py-4 cursor-pointer list-none font-heading text-lg font-semibold text-ink-900 group-open:bg-green-50 transition-colors duration-fast">
            <span class="min-w-0">{it.pergunta}</span>
            <svg
              class="faq-chevron flex-none text-green-700 transition-transform duration-base ease-standard"
              width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"
            >
              <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </summary>
          <div class="px-5 pb-5 font-body text-base text-ink-800 leading-relaxed">{it.resposta}</div>
        </details>
      ))}
    </div>
  )
}

<style>
  .faq-item:not(:last-child) {
    border-bottom: 1px solid var(--border-subtle);
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
  }
</style>
