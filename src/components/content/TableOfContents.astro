---
/**
 * TableOfContents (Índice "Neste artigo") — gerado a partir dos H2/H3 do corpo.
 * Recolhível via <details> nativo (acessível, sem JavaScript). No mobile, vem
 * recolhido por padrão; no desktop lateral, aberto.
 */
interface ItemIndice {
  slug: string;
  text: string;
  depth: number;
}
interface Props {
  items: ItemIndice[];
  title?: string;
  open?: boolean;
}
const { items, title = "Neste artigo", open = false } = Astro.props;
---

{
  items.length > 0 && (
    <details class="toc group bg-white border border-ink-200 rounded-lg overflow-hidden" open={open}>
      <summary
        class="flex items-center justify-between gap-2 w-full min-h-control-md px-5 py-3 cursor-pointer list-none font-heading text-base font-bold text-ink-900"
      >
        <span class="inline-flex items-center gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M8 6h12M8 12h12M8 18h12M4 6h.01M4 12h.01M4 18h.01" stroke="#0A5446" stroke-width="2.2" stroke-linecap="round" />
          </svg>
          {title}
        </span>
        <svg
          class="toc-chevron text-ink-600 transition-transform duration-base ease-standard"
          width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"
        >
          <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </summary>
      <ol class="list-none m-0 px-3 pb-3">
        {items.map((it, i) => (
          <li>
            <a
              href={`#${it.slug}`}
              class={`flex gap-3 items-baseline py-2 px-3 rounded-sm no-underline text-ink-800 text-base leading-normal hover:bg-green-50 ${it.depth >= 3 ? "pl-8" : ""}`}
            >
              <span class="text-green-600 font-bold tabular-nums min-w-[22px]">{i + 1}.</span>
              <span>{it.text}</span>
            </a>
          </li>
        ))}
      </ol>
    </details>
  )
}

<style>
  /* Esconde o triângulo nativo do <summary> e gira o chevron quando aberto */
  .toc summary::-webkit-details-marker {
    display: none;
  }
  .toc[open] .toc-chevron {
    transform: rotate(180deg);
  }
</style>
