---
/**
 * ArticleMeta — sinais de confiança sob o H1: autor (com link para a Sobre),
 * "Atualizado em [data]" e tempo de leitura. Sinais E-E-A-T importam para YMYL.
 */
import Icon from "@components/Icon.astro";
import { getAutor } from "@config/autores";

interface Props {
  autorId?: string;
  /** Data já formatada por extenso (ex.: "12 de junho de 2026"). */
  date: string;
  readingTime?: string;
  reviewed?: boolean;
}
const { autorId, date, readingTime, reviewed = false } = Astro.props;

const autor = getAutor(autorId);
const iniciais = autor.nome
  .split(" ")
  .slice(0, 2)
  .map((w) => w[0])
  .join("")
  .toUpperCase();
---

<div class="flex items-center gap-3 flex-wrap font-body">
  {
    autor.foto ? (
      <img
        src={autor.foto}
        width="44"
        height="44"
        alt={`Foto de ${autor.nome}`}
        class="w-11 h-11 flex-none rounded-pill object-cover"
        loading="lazy"
      />
    ) : (
      <div
        aria-hidden="true"
        class="w-11 h-11 flex-none rounded-pill bg-green-100 text-green-800 flex items-center justify-center font-bold text-sm"
      >
        {iniciais}
      </div>
    )
  }
  <div class="min-w-0 leading-[1.35]">
    <div class="text-base text-ink-900">
      <a href={autor.perfilUrl} class="font-semibold text-ink-900 no-underline hover:underline">{autor.nome}</a>
      <span class="text-ink-600"> · {autor.cargo}</span>
    </div>
    <div class="flex items-center gap-3 flex-wrap text-sm text-ink-600">
      <span>Atualizado em {date}</span>
      {
        readingTime && (
          <span class="inline-flex items-center gap-1">
            <Icon name="clock" size={15} />
            {readingTime} de leitura
          </span>
        )
      }
      {
        reviewed && (
          <span class="inline-flex items-center gap-1 text-green-700 font-semibold">
            <Icon name="shield-check" size={15} />
            Revisado
          </span>
        )
      }
    </div>
  </div>
</div>
