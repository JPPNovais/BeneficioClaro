---
/**
 * ArticleCard — teaser de "Últimos artigos" / "Artigos relacionados". Mostra a
 * miniatura da capa (quando há), a categoria, o título e a meta. A imagem ajuda
 * o usuário a entender do que é o artigo antes de clicar. Card inteiro é link.
 * Sem capa, cai para o modo text-first.
 */
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  href: string;
  category?: string;
  readingTime?: string;
  date?: string;
  cover?: ImageMetadata;
  coverAlt?: string;
  class?: string;
}
const { title, href, category, readingTime, date, cover, coverAlt, class: className = "" } = Astro.props;
---

<a
  href={href}
  class={`group flex flex-col bg-white border border-ink-200 rounded-lg no-underline text-inherit shadow-sm overflow-hidden transition-[box-shadow,transform] duration-base hover:shadow-md hover:-translate-y-0.5 h-full ${className}`}
>
  {
    cover && (
      <div class="w-full aspect-[16/9] overflow-hidden bg-green-900">
        <Image
          src={cover}
          alt={coverAlt ?? title}
          widths={[400, 800]}
          sizes="(min-width: 1024px) 360px, 100vw"
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover transition-transform duration-base group-hover:scale-[1.03]"
        />
      </div>
    )
  }
  <div class="flex flex-col gap-2 p-5 flex-1">
    {
      category && (
        <span class="self-start px-[10px] py-[3px] rounded-pill bg-green-100 text-green-800 font-body text-xs font-bold">
          {category}
        </span>
      )
    }
    <span
      class="font-heading text-xl font-bold text-ink-900 leading-snug [text-wrap:balance] group-hover:underline underline-offset-2"
    >
      {title}
    </span>
    <span class="mt-auto pt-2 flex gap-3 items-center font-body text-sm text-ink-600">
      {date && <span>{date}</span>}
      {readingTime && <span>· {readingTime} de leitura</span>}
    </span>
  </div>
</a>
