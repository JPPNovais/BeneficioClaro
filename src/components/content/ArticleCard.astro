---
/**
 * ArticleCard — teaser de "Últimos artigos" / "Artigos relacionados".
 * Tag de categoria + título + meta curta. O card inteiro é um link.
 */
interface Props {
  title: string;
  href: string;
  category?: string;
  readingTime?: string;
  date?: string;
  class?: string;
}
const { title, href, category, readingTime, date, class: className = "" } = Astro.props;
---

<a
  href={href}
  class={`group flex flex-col gap-2 p-5 bg-white border border-ink-200 rounded-lg no-underline text-inherit shadow-sm transition-[box-shadow,transform] duration-base hover:shadow-md hover:-translate-y-0.5 h-full ${className}`}
>
  {
    category && (
      <span class="self-start px-[10px] py-[3px] rounded-pill bg-green-100 text-green-800 font-body text-xs font-bold">
        {category}
      </span>
    )
  }
  <span
    class="font-heading text-xl font-bold text-ink-900 leading-snug [text-wrap:balance] group-hover:underline underline-offset-2"
  >
    {title}
  </span>
  <span class="mt-auto pt-2 flex gap-3 items-center font-body text-sm text-ink-600">
    {date && <span>{date}</span>}
    {readingTime && <span>· {readingTime} de leitura</span>}
  </span>
</a>
