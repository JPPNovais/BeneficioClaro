---
/**
 * BaseHead — tudo do <head> relacionado a SEO/AEO e performance:
 * <title>, meta description, canonical, Open Graph, Twitter Card, robots,
 * preconnect de fontes, favicon e o loader do AdSense (quando ativo).
 */
import { SITE, ADSENSE } from "@config/site";
import { urlAbsoluta } from "@lib/utils";

interface Props {
  title: string;
  description?: string;
  /** Caminho canônico; por padrão usa a URL atual. */
  canonical?: string;
  image?: string;
  type?: "website" | "article";
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description = SITE.descricao,
  canonical,
  image = SITE.ogImage,
  type = "website",
  noindex = false,
  publishedTime,
  modifiedTime,
} = Astro.props;

// Título: páginas internas ganham o sufixo da marca — mas só se não passar de
// ~60 caracteres (senão o Google trunca no resultado da busca).
const sufixo = ` | ${SITE.nome}`;
const tituloCompleto =
  title === SITE.nome ? title : title.length + sufixo.length <= 60 ? `${title}${sufixo}` : title;

const pathnameLimpo = Astro.url.pathname.replace(/\/$/, "") || "/";
const canonicalUrl = urlAbsoluta(Astro.site ?? SITE.url, canonical ?? pathnameLimpo);
const imageUrl = image.startsWith("http") ? image : urlAbsoluta(Astro.site ?? SITE.url, image);

const adsenseLoader = ADSENSE.ativo && ADSENSE.publisherId.startsWith("ca-pub-");
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<title>{tituloCompleto}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"} />
<meta name="theme-color" content="#0D6B57" />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE.nome} />
<meta property="og:locale" content="pt_BR" />
<meta property="og:title" content={tituloCompleto} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={imageUrl} />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={tituloCompleto} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" href="/logo-mark.svg" />

<!-- Feed RSS (descoberta e frescor) -->
<link rel="alternate" type="application/rss+xml" title={`${SITE.nome} — Artigos`} href="/rss.xml" />

<!-- Fontes auto-hospedadas: preload dos 2 pesos mais usados (corpo + títulos) -->
<link rel="preload" href="/fonts/public-sans-400-latin.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="/fonts/libre-franklin-800-latin.woff2" as="font" type="font/woff2" crossorigin />

{
  adsenseLoader && (
    <script
      async
      src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE.publisherId}`}
      crossorigin="anonymous"
      is:inline
    />
  )
}
