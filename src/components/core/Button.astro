---
/**
 * Button — controle de ação principal. Fiel ao Button do design.
 *  - cta (laranja): a ação mais importante da tela.
 *  - primary (verde): confirmações padrão.
 *  - secondary (contorno) e ghost: ênfase menor.
 * Altura respeita o piso de toque de 44px; `lg` para CTAs de herói / mobile.
 * Renderiza <a> quando recebe `href`, senão <button>.
 */
interface Props {
  variant?: "cta" | "primary" | "secondary" | "ghost";
  size?: "sm" | "md" | "lg";
  fullWidth?: boolean;
  disabled?: boolean;
  href?: string;
  type?: "button" | "submit" | "reset";
  id?: string;
  class?: string;
  [key: string]: any;
}

const {
  variant = "primary",
  size = "md",
  fullWidth = false,
  disabled = false,
  href,
  type = "button",
  class: className = "",
  ...rest
} = Astro.props;

const sizes = {
  sm: "min-h-control-sm h-control-sm px-[14px] text-sm",
  md: "min-h-control-md h-control-md px-5 text-base",
  lg: "min-h-control-lg h-control-lg px-7 text-lg",
};

const palettes = {
  cta: "bg-cta text-white border-transparent shadow-xs hover:bg-cta-hover",
  primary: "bg-primary text-white border-transparent shadow-xs hover:bg-primary-strong",
  secondary: "bg-transparent text-primary-strong border-green-600 hover:bg-green-50",
  ghost: "bg-transparent text-ink-900 border-transparent hover:bg-ink-100",
};

const base =
  "inline-flex items-center justify-center gap-2 font-body font-bold leading-none rounded-md border-thick whitespace-nowrap no-underline transition-colors duration-fast ease-standard";

const disabledCls = "bg-ink-200 text-ink-500 border-transparent cursor-not-allowed shadow-none";

const cls = [
  base,
  sizes[size],
  disabled ? disabledCls : palettes[variant],
  fullWidth ? "w-full" : "w-auto",
  className,
].join(" ");

const Tag = href ? "a" : "button";
---

<Tag
  class={cls}
  href={href}
  type={href ? undefined : type}
  aria-disabled={disabled ? "true" : undefined}
  {...rest}
>
  <slot name="leading" />
  <slot />
  <slot name="trailing" />
</Tag>
