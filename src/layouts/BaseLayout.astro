---
/**
 * BaseLayout — shell HTML de todas as páginas. Inclui o <head> de SEO, o estilo
 * global, o link "pular para o conteúdo" (acessibilidade), header, <main> e
 * footer. Injeta o schema base (WebSite + Organization) em toda página.
 */
import "@styles/global.css";
import BaseHead from "@components/seo/BaseHead.astro";
import JsonLd from "@components/seo/JsonLd.astro";
import SiteHeader from "@components/SiteHeader.astro";
import SiteFooter from "@components/SiteFooter.astro";
import { SITE } from "@config/site";
import { urlAbsoluta } from "@lib/utils";
import { websiteSchema, organizationSchema, webPageSchema, graph } from "@lib/seo";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: "website" | "article";
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  /** Schema adicional específico da página (Article, FAQ, etc.). */
  schema?: object[];
}

const { schema = [], ...head } = Astro.props;

// WebPage por página, ligado ao WebSite (canonical como @id).
const pathnameLimpo = Astro.url.pathname.replace(/\/$/, "") || "/";
const canonicalUrl = urlAbsoluta(Astro.site ?? SITE.url, head.canonical ?? pathnameLimpo);
const webPage = webPageSchema({
  url: canonicalUrl,
  name: head.title ?? SITE.nome,
  description: head.description ?? SITE.descricao,
});

const baseGraph = graph([websiteSchema(), organizationSchema(), webPage, ...schema]);
---

<!doctype html>
<html lang={SITE.locale}>
  <head>
    <BaseHead {...head} />
    <JsonLd data={baseGraph} />
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#conteudo" class="skip-link">Pular para o conteúdo</a>
    <SiteHeader />
    <main id="conteudo" class="flex-1">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
